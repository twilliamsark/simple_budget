{
  "name": "SimpleBudget",
  "productName": "SimpleBudget",
  "version": "0.0.0",
  "main": "dist/electron/main.js",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "start": "npm run electron:compile && electron-forge start",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "package": "npm run electron:compile && electron-forge package",
    "make": "npm run electron:compile && electron-forge make",
    "electron:dev": "npm run electron:compile && concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron-forge start\"",
    "electron:build": "ng build --configuration production && npm run electron:compile && electron-forge make",
    "electron:package": "ng build --configuration production && npm run electron:compile && electron-forge package",
    "electron:start": "electron-forge start"
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "chart.js": "^4.5.1",
    "electron-squirrel-startup": "^1.0.1",
    "ng2-charts": "^10.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
